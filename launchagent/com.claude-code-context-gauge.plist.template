<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.claude-code-context-gauge</string>

  <!-- Re-run the patch whenever the VSCode extensions registry changes.
       VSCode rewrites extensions.json on every install/update/uninstall,
       so this fires right after the extension is updated, before you
       reopen the editor. __HOME__ is substituted by install.sh. -->
  <key>WatchPaths</key>
  <array>
    <string>__HOME__/.vscode/extensions/extensions.json</string>
  </array>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/python3</string>
    <string>__REPO__/scripts/patch_gauge.py</string>
  </array>

  <!-- Also run once at login, in case an update happened while logged out. -->
  <key>RunAtLoad</key>
  <true/>

  <key>StandardOutPath</key>
  <string>__REPO__/scripts/launchagent.out.log</string>
  <key>StandardErrorPath</key>
  <string>__REPO__/scripts/launchagent.err.log</string>
</dict>
</plist>
